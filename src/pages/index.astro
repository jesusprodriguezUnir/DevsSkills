<script>
  function setupSearch() {
    const searchInput = document.getElementById(
      "skill-search",
    ) as HTMLInputElement;
    const grid = document.getElementById("skills-grid")!;
    const cards = grid.querySelectorAll<HTMLElement>(".skill-card");
    const filterButtons =
      document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const visibleCount = document.getElementById("visible-count")!;
    const emptyState = document.getElementById("empty-state")!;
    const total = cards.length;

    let activeCategory = "all";

    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      let visible = 0;

      cards.forEach((card) => {
        const title =
          card.querySelector(".card-title")?.textContent?.toLowerCase() || "";
        const desc =
          card.querySelector(".card-description")?.textContent?.toLowerCase() ||
          "";
        const category = card.getAttribute("data-category") || "";

        const matchesSearch =
          !query || title.includes(query) || desc.includes(query);
        const matchesCategory =
          activeCategory === "all" || category === activeCategory;
        const show = matchesSearch && matchesCategory;

        card.style.display = show ? "" : "none";
        if (show) visible++;
      });

      visibleCount.textContent = `${visible} de ${total}`;
      emptyState.style.display = visible === 0 ? "" : "none";
      grid.style.display = visible === 0 ? "none" : "";
    }

    searchInput.addEventListener("input", applyFilters);

    searchInput.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        searchInput.value = "";
        searchInput.blur();
        applyFilters();
      }
    });

    filterButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterButtons.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        activeCategory = btn.getAttribute("data-filter") || "all";
        applyFilters();
      });
    });

    // Keyboard shortcut: / to focus search
    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
      }
    });

    // Theme Toggle Logic
    const themeBtn = document.getElementById("theme-toggle");

    function updateThemeIcon(theme) {
      const sun = document.getElementById("sun-icon");
      const moon = document.getElementById("moon-icon");
      if (sun && moon) {
        if (theme === "light") {
          sun.style.display = "none";
          moon.style.display = "block";
        } else {
          sun.style.display = "block";
          moon.style.display = "none";
        }
      }
    }

    if (themeBtn) {
      themeBtn.addEventListener("click", () => {
        const element = document.documentElement;
        const currentTheme = element.getAttribute("data-theme") || "dark";
        const targetTheme = currentTheme === "light" ? "dark" : "light";

        element.setAttribute("data-theme", targetTheme);
        localStorage.setItem("theme", targetTheme);
        updateThemeIcon(targetTheme);
      });
      // Set initial icon
      updateThemeIcon(
        document.documentElement.getAttribute("data-theme") || "dark",
      );
    }
  }

  setupSearch();
  document.addEventListener("astro:after-swap", setupSearch);
</script>

<style>
  /* ─── Hero ─── */
  .hero {
    text-align: center;
    padding-bottom: 3rem;
    margin-bottom: 2rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 1.1rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent-bright);
    margin-bottom: 2rem;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.8);
    }
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .title-line {
    color: var(--text-primary);
  }

  .title-accent {
    background: linear-gradient(
      135deg,
      var(--accent),
      #c084fc,
      var(--accent-bright)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-line-2 {
    display: block;
    color: var(--text-secondary);
    font-size: 0.4em;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.3em;
  }

  .hero-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem 2.5rem;
    border-radius: var(--radius-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-value {
    font-family: "Outfit", sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-color);
  }

  /* ─── Toolbar ─── */
  .toolbar {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .toolbar-top {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .search-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast);
  }

  .search-wrapper:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .search-icon {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  #skill-search {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-family: "Inter", sans-serif;
    outline: none;
  }

  #skill-search::placeholder {
    color: var(--text-tertiary);
  }

