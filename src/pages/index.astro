---
import Layout from '../layouts/Layout.astro';
import SkillCard from '../components/SkillCard.astro';
import fs from 'node:fs';
import path from 'node:path';

interface Skill {
  id: string;
  name: string;
  description: string;
  category: string;
  license: string;
  compatibility: string | null;
  fileCount: number;
  rawSize: number;
  zipSize: number;
  subdirs: string[];
  body: string;
  downloadUrl: string;
  image: string | null;
}

// Read the generated manifest
const manifestPath = path.join(process.cwd(), 'src/data/skills-manifest.json');
const skills: Skill[] = JSON.parse(fs.readFileSync(manifestPath, 'utf-8'));

// Resolve download URLs with base path (for GitHub Pages subpath deployment)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
skills.forEach((s) => {
  s.downloadUrl = `${base}${s.downloadUrl}`;
  if (s.image) {
    s.image = `${base}${s.image}`;
  }
});

// Compute stats
const categories = [...new Set(skills.map((s) => s.category))];
const totalSize = skills.reduce((acc, s) => acc + s.rawSize, 0);
---

<Layout title="DevSkills Hub — Catálogo de Skills para Agentes IA">
  <main>
    <!-- ─── Hero ─── -->
    <header class="hero fade-in-up">
      <div class="hero-badge glass">
        <span class="pulse-dot"></span>
        <span>{skills.length} skills disponibles</span>
      </div>

      <h1 class="hero-title">
        <span class="title-line">Dev</span><span class="title-accent">Skills</span>
        <span class="title-line-2">Hub</span>
      </h1>

      <p class="hero-subtitle">
        Catálogo interactivo de skills para agentes de IA.<br />
        Explora, previsualiza y descarga skills listas para usar.
      </p>

      <div class="hero-stats glass">
        <div class="stat">
          <span class="stat-value">{skills.length}</span>
          <span class="stat-label">Skills</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">{categories.length}</span>
          <span class="stat-label">Categorías</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">{(totalSize / 1024).toFixed(0)}</span>
          <span class="stat-label">KB totales</span>
        </div>
      </div>
    </header>

    <!-- ─── Toolbar ─── -->
    <section class="toolbar fade-in-up" style="animation-delay: 200ms">
      <div class="search-wrapper glass">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          type="text"
          id="skill-search"
          aria-label="Buscar skills"
          placeholder="Buscar skills por nombre o descripción..."
          autocomplete="off"
        />
        <kbd class="search-kbd">ESC</kbd>
      </div>

      <div class="filter-row">
        <button class="filter-btn active" data-filter="all">
          Todas
          <span class="filter-count">{skills.length}</span>
        </button>
        {categories.map((cat) => {
          const count = skills.filter((s) => s.category === cat).length;
          return (
            <button class="filter-btn" data-filter={cat}>
              {cat}
              <span class="filter-count">{count}</span>
            </button>
          );
        })}
      </div>
    </section>

    <!-- ─── Grid ─── -->
    <section class="skills-section">
      <div class="grid-header">
        <h2>Skills Disponibles</h2>
        <span id="visible-count" class="visible-count" aria-live="polite" aria-atomic="true">{skills.length} de {skills.length}</span>
      </div>

      <div class="skills-grid" id="skills-grid">
        {skills.map((skill, idx) => (
          <SkillCard
            id={skill.id}
            name={skill.name}
            description={skill.description}
            category={skill.category}
            license={skill.license}
            fileCount={skill.fileCount}
            rawSize={skill.rawSize}
            zipSize={skill.zipSize}
            subdirs={skill.subdirs}
            body={skill.body}
            downloadUrl={skill.downloadUrl}
            image={skill.image}
            index={idx}
          />
        ))}
      </div>

      <div id="empty-state" class="empty-state" style="display: none;">
        <div class="empty-icon">🔍</div>
        <h3>Sin resultados</h3>
        <p>No se encontraron skills con ese filtro. Prueba con otro término.</p>
      </div>
    </section>

    <!-- ─── Resources Footer ─── -->
    <footer class="resources-footer fade-in-up" style="animation-delay: 400ms">
      <div class="resources-header">
        <h2 class="resources-title">Encuentra más skills</h2>
        <p class="resources-subtitle">Catálogos y repositorios externos de la comunidad</p>
      </div>
      <div class="resources-grid">
        <a href="https://www.aitmpl.com/" target="_blank" rel="noopener noreferrer" class="resource-card glass">
          <div class="resource-card-content">
            <span class="resource-card-name">aitmpl.com</span>
            <span class="resource-card-desc">Plantillas y prompts para agentes de IA listos para usar</span>
          </div>
          <svg class="resource-card-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
        <a href="https://awesomeclaude.ai/" target="_blank" rel="noopener noreferrer" class="resource-card glass">
          <div class="resource-card-content">
            <span class="resource-card-name">awesomeclaude.ai</span>
            <span class="resource-card-desc">Lista curada de recursos, herramientas y skills para Claude</span>
          </div>
          <svg class="resource-card-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
        <a href="https://skills.sh/" target="_blank" rel="noopener noreferrer" class="resource-card glass">
          <div class="resource-card-content">
            <span class="resource-card-name">skills.sh</span>
            <span class="resource-card-desc">Directorio de skills para agentes con Claude Code</span>
          </div>
          <svg class="resource-card-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
      <div class="footer-copy">
        <span>© 2025 DevSkills Hub</span>
      </div>
    </footer>
  </main>
</Layout>

<script>
  function setupSearch() {
    const searchInput = document.getElementById('skill-search') as HTMLInputElement;
    const grid = document.getElementById('skills-grid')!;
    const cards = grid.querySelectorAll<HTMLElement>('.skill-card');
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const visibleCount = document.getElementById('visible-count')!;
    const emptyState = document.getElementById('empty-state')!;
    const total = cards.length;

    let activeCategory = 'all';

    function applyFilters() {
      const query = searchInput.value.toLowerCase().trim();
      let visible = 0;

      cards.forEach(card => {
        const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || '';
        const desc = card.querySelector('.card-description')?.textContent?.toLowerCase() || '';
        const category = card.getAttribute('data-category') || '';

        const matchesSearch = !query || title.includes(query) || desc.includes(query);
        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const show = matchesSearch && matchesCategory;

        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      visibleCount.textContent = `${visible} de ${total}`;
      emptyState.style.display = visible === 0 ? '' : 'none';
      grid.style.display = visible === 0 ? 'none' : '';
    }

    searchInput.addEventListener('input', applyFilters);

    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        searchInput.blur();
        applyFilters();
      }
    });

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });

    // Keyboard shortcut: / to focus search
    document.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
      }
    });
  }

  setupSearch();
  document.addEventListener('astro:after-swap', setupSearch);
</script>

<style>
  /* ─── Hero ─── */
  .hero {
    text-align: center;
    padding-bottom: 3rem;
    margin-bottom: 2rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 1.1rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent-bright);
    margin-bottom: 2rem;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    margin-bottom: 1.5rem;
  }

  .title-line {
    color: var(--text-primary);
  }

  .title-accent {
    background: linear-gradient(135deg, var(--accent), #c084fc, var(--accent-bright));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .title-line-2 {
    display: block;
    color: var(--text-secondary);
    font-size: 0.4em;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.3em;
  }

  .hero-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem 2.5rem;
    border-radius: var(--radius-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-value {
    font-family: 'Outfit', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-color);
  }

  /* ─── Toolbar ─── */
  .toolbar {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast);
  }

  .search-wrapper:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .search-icon {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  #skill-search {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-family: 'Inter', sans-serif;
    outline: none;
  }

  #skill-search::placeholder {
    color: var(--text-tertiary);
  }

  .search-kbd {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-tertiary);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    flex-shrink: 0;
  }

  .filter-row {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: 99px;
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.03);
  }

  .filter-btn.active {
    background: var(--accent-glow);
    border-color: var(--accent);
    color: var(--accent-bright);
  }

  .filter-count {
    font-size: 0.65rem;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1rem 0.4rem;
    border-radius: 99px;
    font-weight: 600;
  }

  .filter-btn.active .filter-count {
    background: rgba(129, 140, 248, 0.2);
    color: var(--accent-bright);
  }

  /* ─── Grid ─── */
  .skills-section {
    margin-top: 1rem;
  }

  .grid-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .grid-header h2 {
    font-size: 1.6rem;
  }

  .visible-count {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.25rem;
  }

  /* ─── Empty State ─── */
  .empty-state {
    text-align: center;
    padding: 5rem 2rem;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.6;
  }

  .empty-state h3 {
    color: var(--text-primary);
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero-stats {
      gap: 1.25rem;
      padding: 1rem 1.5rem;
    }

    .stat-value {
      font-size: 1.3rem;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .filter-row {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 0.5rem;
      -webkit-overflow-scrolling: touch;
    }

    .filter-btn {
      flex-shrink: 0;
    }
  }

  /* ─── Resources Footer ─── */
  .resources-footer {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border-color);
  }

  .resources-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .resources-title {
    font-size: 1.4rem;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .resources-subtitle {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .resource-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--transition-fast), transform var(--transition-fast), background var(--transition-fast);
  }

  .resource-card:hover {
    border-color: var(--accent);
    background: var(--card-bg-hover);
    transform: translateY(-2px);
  }

  .resource-card:hover .resource-card-arrow {
    transform: translate(2px, -2px);
    color: var(--accent-bright);
  }

  .resource-card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .resource-card-name {
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent-bright);
  }

  .resource-card-desc {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .resource-card-arrow {
    flex-shrink: 0;
    color: var(--text-tertiary);
    transition: transform var(--transition-fast), color var(--transition-fast);
  }

  .footer-copy {
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    padding-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .resources-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
