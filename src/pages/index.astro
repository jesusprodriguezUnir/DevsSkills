    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero-stats {
