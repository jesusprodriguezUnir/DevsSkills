---
interface Props {
  title: string;
  category: string;
  description: string;
  rawContent: string;
  tags?: string[];
}

const { title, category, description, rawContent, tags = [] } = Astro.props;
---

<div class="skill-card glass fade-in">
  <div class="card-header">
    <span class="category-badge">{category}</span>
    <div class="tags">
      {tags.map(tag => <span class="tag">#{tag}</span>)}
    </div>
  </div>
  
  <h3>{title}</h3>
  <p>{description}</p>
  
  <div class="card-footer">
    <button class="view-btn glass" data-modal-id={`modal-${title.toLowerCase().replace(/\s+/g, '-')}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
      Ver Skill
    </button>
    <button 
      class="download-btn" 
      data-content={rawContent} 
      data-filename={`${title.toLowerCase().replace(/\s+/g, '-')}.md`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Descargar
    </button>
  </div>
</div>

<dialog id={`modal-${title.toLowerCase().replace(/\s+/g, '-')}`} class="skill-modal glass">
  <div class="modal-content">
    <div class="modal-header">
      <h2>{title}</h2>
      <button class="close-btn">&times;</button>
    </div>
    <div class="modal-body">
      <pre><code>{rawContent}</code></pre>
    </div>
  </div>
</dialog>

<script>
  function setupComponents() {
    const downloadButtons = document.querySelectorAll('.download-btn');
    const viewButtons = document.querySelectorAll('.view-btn');
    
    downloadButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const content = target.getAttribute('data-content') || '';
        const filename = target.getAttribute('data-filename') || 'skill.md';
        
        const blob = new Blob([content], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        
        // Visual feedback
        const originalText = target.innerHTML;
        target.innerHTML = '¡Listo!';
        target.classList.add('success');
        setTimeout(() => {
          target.innerHTML = originalText;
          target.classList.remove('success');
        }, 2000);
      });
    });

    viewButtons.forEach(button => {
      button.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const modalId = target.getAttribute('data-modal-id');
        const modal = document.getElementById(modalId!) as HTMLDialogElement;
        if (modal) {
          modal.showModal();
          document.body.style.overflow = 'hidden';
        }
      });
    });

    document.querySelectorAll('.close-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const modal = (e.target as HTMLElement).closest('dialog');
        modal?.close();
        document.body.style.overflow = 'auto';
      });
    });

    // Close on backdrop click
    document.querySelectorAll('dialog').forEach(modal => {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.close();
          document.body.style.overflow = 'auto';
        }
      });
    });
  }

  // Run on first load and after transitions
  setupComponents();
  document.addEventListener('astro:after-swap', setupComponents);
</script>

<style>
  .skill-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease;
    height: 100%;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent);
    box-shadow: 0 10px 30px -10px var(--accent-glow);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-badge {
    background: var(--accent-glow);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid rgba(99, 102, 241, 0.2);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--text-secondary);
  }

  h3 {
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .card-footer {
    margin-top: auto;
    display: flex;
    gap: 0.75rem;
  }

  .view-btn, .download-btn {
    flex: 1;
    padding: 0.8rem;
    border: none;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .view-btn {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }

  .view-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--text-secondary);
  }

  .download-btn {
    background: var(--text-primary);
    color: var(--bg-color);
  }

  .download-btn:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-2px);
  }

  /* Modal Styles */
  .skill-modal {
    padding: 0;
    max-width: 800px;
    width: 90%;
    max-height: 80vh;
    border-color: rgba(99, 102, 241, 0.3);
    color: white;
    outline: none;
  }

  .skill-modal::backdrop {
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .modal-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 2rem;
  }

  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .modal-header h2 {
    font-size: 1.8rem;
    color: var(--accent);
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
  }

  .modal-body {
    overflow-y: auto;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 8px;
    padding: 1.5rem;
  }

  pre {
    white-space: pre-wrap;
    word-break: break-all;
    font-family: 'Inter', monospace;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #d1d1d1;
  }

  .download-btn.success {
    background: #10b981;
    color: white;
  }

  svg {
    transition: transform 0.2s ease;
  }

  .download-btn:hover svg {
    transform: translateY(2px);
  }
</style>
